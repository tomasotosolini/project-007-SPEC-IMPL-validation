<h1>Login</h1>

<% if @error %>
  <p><%= @error %></p>
<% end %>

<%= form_with url: login_path, method: :post do |f| %>
  <div>
    <%= f.label :username %>
    <%= f.text_field :username, value: params[:username] %>
  </div>
  <div>
    <%= f.label :password %>
    <%= f.password_field :password %>
  </div>
  <%= f.submit "Login" %>
<% end %>
